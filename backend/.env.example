# Copy this file to backend/.env and fill in values.
# Do NOT commit backend/.env (it contains secrets).

# Gemini API key used by the backend.
GEMINI_API_KEY=

# Where to persist ChromaDB. If relative, it's resolved against backend/.
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Comma-separated list of allowed origins for CORS.
# Include your frontend dev server (e.g. :3000) and/or the backend itself (e.g. :8000).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# FastAPI port
PORT=8000

# Enable auto-reload for local development
UVICORN_RELOAD=false

