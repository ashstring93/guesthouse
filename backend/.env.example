# ── AI 챗봇 ──
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# ── 서버 ──
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: move SQLite outside the source tree when using Docker
# DB_PATH=/data/guesthouse.db

# ── 숙소 요금 ──
BASE_WEEKDAY_RATE=184847
BASE_WEEKEND_RATE=242612
BASE_GUESTS=2
MAX_GUESTS=8
ADULT_EXTRA_FEE=20000
BBQ_FEE=20000

# ── 토스페이먼츠 (V2) ──
TOSSPAYMENTS_WIDGET_CLIENT_KEY=
# 상점관리자에서 가상계좌를 제거한 결제 UI variantKey
TOSSPAYMENTS_PAYMENT_METHOD_VARIANT_KEY=DEFAULT
TOSSPAYMENTS_SECRET_KEY=
TOSSPAYMENTS_API_BASE=https://api.tosspayments.com
PAYMENT_TERMS_VERSION=2026-03-09-v1
BOOKED_STATUSES=confirming,confirmed,paid

# ── 관리자 대시보드 ──
ADMIN_DASHBOARD_TOKEN=
